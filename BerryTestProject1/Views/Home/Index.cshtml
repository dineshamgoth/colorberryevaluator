<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard</title>
    <!-- Tailwind CSS for styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* Applying Poppins font to the body */
        body {
            font-family: 'Poppins', sans-serif;
        }

        /* Keyframes for the gradient position animation remains the same */
        @@keyframes gradient-animation {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        /* Animation class for the username */
        .animated-gradient-name {
            /* This gradient excludes green and yellow */
            background-image: linear-gradient(90deg, #9400D3, /* Violet */
            #FF0000, /* Red */
            #4B0082, /* Indigo */
            #0000FF, /* Blue */
            #FF7F00, /* Orange */
            #9400D3, /* Violet */
            #FF0000, /* Red */
            #4B0082, /* Indigo */
            #9400D3 /* Violet to ensure a seamless loop */
            );
            background-size: 1600% auto;
            animation: gradient-animation 180s ease-in-out infinite;
        }

        /* Animation class specifically for the button */
        .animated-gradient-button {
            /* This gradient includes all VIBGYOR colors */
            background-image: linear-gradient(90deg, #9400D3, /* Violet */
            #FF0000, /* Red */
            #00FF00, /* Green */
            #4B0082, /* Indigo */
            #FFFF00, /* Yellow */
            #0000FF, /* Blue */
            #FF7F00, /* Orange */
            #9400D3, /* Violet */
            #00FF00, /* Green */
            #FF0000, /* Red */
            #4B0082, /* Indigo */
            #FFFF00, /* Yellow */
            #9400D3 /* Violet to ensure a seamless loop */
            );
            background-size: 1600% auto;
            /* Slightly different duration to de-sync from the name animation */
            animation: gradient-animation 175s ease-in-out infinite;
            transition: animation-duration 0.5s ease-in-out;
        }

            /* The hover effect now ONLY applies to the button's gradient */
            .animated-gradient-button:hover {
                animation-duration: 5s;
            }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">
    <div class="min-h-screen flex flex-col items-center justify-center p-4">

        <!-- Header Section -->
        <header class="text-center mb-8">
            <h1 class="text-4xl md:text-5xl font-medium">
                <span class="text-transparent bg-clip-text animated-gradient-name font-semibold">
                    @ViewBag.Name
                </span>
            </h1>
            <p class="text-gray-500 mt-2 text-lg">We're happy to see you again!</p>
        </header>

        <!-- Main Content: Button -->
        <main>
            <div class="text-center">
                <form method="post" action="/Home/Evaluate">
                    <div class="inline-block p-[3px] animated-gradient-button rounded-lg shadow-md hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-indigo-300 transition-all duration-300 ease-in-out">
                        <button type="submit" class="bg-white text-purple-900 font-medium py-3 px-8 rounded-md hover:bg-gray-100 transition-all duration-300 ease-in-out">
                            Evaluate
                        </button>
                    </div>
                </form>
            </div>
        </main>

    </div>
</body>
</html>