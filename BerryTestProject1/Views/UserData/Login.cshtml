@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account - Sign In</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Custom Styles -->
    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }

        /* Custom focus styles for better accessibility and aesthetics */
        .custom-focus-ring:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(129, 140, 248, 0.4);
            border-color: #818cf8;
        }

        /* Style for invalid fields */
        .field-error {
            border-color: #ef4444 !important; /* red-500 */
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <div class="min-h-screen flex items-center justify-center p-4" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
        <div class="w-full max-w-lg mx-auto bg-white rounded-2xl shadow-xl p-8 md:p-12 space-y-8">

            <header class="text-center">
                <p class="text-2xl md:text-3xl font-semibold text-gray-700">Sign In to Your Account</p>
            </header>

            <form id="signinForm" asp-controller="UserData" asp-action="Login" method="post" class="space-y-2" novalidate>
                <div class="mb-4">
                    <label for="username" class="block text-base font-medium text-gray-600 mb-1">Username or Email</label>
                    <input type="text" id="username" name="Username" class="w-full px-4 py-3 bg-gray-100 border-2 border-transparent rounded-lg text-gray-800 focus:bg-white custom-focus-ring transition-all duration-300" required>
                    <div id="usernameOrEmail-error" class="text-red-500 text-sm mt-1 h-5"></div>
                </div>

                <div class="mb-4">
                    <label for="signin-password" class="block text-base font-medium text-gray-600 mb-1">Password</label>
                    <input type="password" id="signin-password" name="Password" class="w-full px-4 py-3 bg-gray-100 border-2 border-transparent rounded-lg text-gray-800 focus:bg-white custom-focus-ring transition-all duration-300" required>
                    <div id="signin-password-error" class="text-red-500 text-sm mt-1 h-5"></div>
                </div>

                <div class="text-center pt-4">
                    <button type="submit" class="bg-transparent border-2 border-purple-600 text-purple-600 font-medium py-3 px-12 rounded-xl hover:shadow-lg hover:shadow-gray-300/50 focus:outline-none focus:ring-4 focus:ring-purple-300 transition-all duration-300 ease-in-out text-xl">
                        Sign In
                    </button>
                </div>
            </form>
            <p class="text-center mt-4 text-gray-600">
                Don't have an account?
                <a href="@Url.Action("Register", "UserData")" class="text-purple-600 hover:underline">Sign Up</a>
            </p>
        </div>

        <div id="success-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center">
            <div class="bg-white p-8 rounded-lg shadow-lg text-center">
                <h3 class="text-2xl font-bold text-green-600 mb-4">Success!</h3>
                <p id="success-message" class="text-gray-700 mb-6"></p>
                <button id="close-modal" class="bg-purple-600 text-white py-2 px-6 rounded-md hover:bg-purple-700">Close</button>
            </div>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const signinForm = document.getElementById('signinForm');
            const usernameInput = document.getElementById('username');
            const signinPasswordInput = document.getElementById('signin-password');

            const showError = (input, message) => {
                const errorElement = document.getElementById(input.id + '-error');
                input.classList.toggle('field-error', !!message);
                if(errorElement) errorElement.textContent = message;
            };

            signinForm.addEventListener('submit', e => {
                let isValid = true;

                // Clear previous errors
                showError(usernameInput, '');
                showError(signinPasswordInput, '');

                if (!usernameInput.value.trim()) {
                    showError(usernameInput, 'Username is required.');
                    isValid = false;
                }

                if (!signinPasswordInput.value.trim()) {
                    showError(signinPasswordInput, 'Password is required.');
                    isValid = false;
                }

                if (!isValid) {
                    e.preventDefault(); // Stop submission if client-side validation fails
                }
            });
        });
    </script>
</body>
</html>